{
  "name": "tech-test",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "start": "vite serve --port 10000 --strictPort",
    "test": "cypress run --component --headless",
    "cypress:unit": "cypress open --component",
    "cypress:e2e": "cypress open --e2e",
    "test:coverage": "nyc report --reporter=lcov --branches=1 --functions=1 --lines=1 --statements=1",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@cypress/code-coverage": "^3.12.12",
    "babel-plugin-istanbul": "^6.1.1",
    "cypress": "^12.17.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "msw": "^1.3.0",
    "nyc": "^15.1.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^4.5.0",
    "vite-plugin-istanbul": "^5.0.0"
  }
}
